# ---- Production web frontend image for open-agent ----
# Builds the Vite React app and serves the static files with nginx.
FROM node:20-slim AS builder

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY . .
RUN npm run build

# ---- Runtime stage ----
FROM nginx:alpine

# Copy the built static assets to nginx's default web root.
COPY --from=builder /app/dist /usr/share/nginx/html

# Copy a minimal nginx configuration that proxies API/WebSocket requests.
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
