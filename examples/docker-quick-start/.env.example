# Open Agent — Docker Quick Start 最小配置模板
#
# 用法：复制本文件为 .env，再按需修改。
#   cp .env.example .env          (Linux/macOS)
#   Copy-Item .env.example .env   (Windows PowerShell)
#
# 只有 OPEN_AGENT_API_KEY 是必填项（使用 OpenAI 时）。其余都有合理默认值。

# Required: your OpenAI API key
OPEN_AGENT_API_KEY=sk-your-key-here

# Optional: switch provider (openai | anthropic | ollama)
OPEN_AGENT_MODEL_PROVIDER=openai

# Optional: model name
OPEN_AGENT_MODEL_NAME=gpt-4o-mini

# Optional: use local Ollama instead (comment out API_KEY above)
# OPEN_AGENT_MODEL_PROVIDER=ollama
# OPEN_AGENT_BASE_URL=http://host.docker.internal:11434/v1
# OPEN_AGENT_API_KEY=ollama
# OPEN_AGENT_MODEL_NAME=llama3.2
