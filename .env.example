# Copy this file to .env and fill in your values before running docker compose up.

# ---- Model settings ----
# Supported providers: openai | anthropic | ollama | zhipu
# 20+ other providers (DeepSeek, Moonshot, Qwen, Groq, Mistral, ...) work via
# MODEL_PROVIDER=openai + a custom BASE_URL — see docs/configuration.md
# "OpenAI compatible provider quick reference" for the full base_url list.
OPEN_AGENT_MODEL_PROVIDER=openai
OPEN_AGENT_API_KEY=your-api-key-here
OPEN_AGENT_BASE_URL=https://api.openai.com/v1
OPEN_AGENT_MODEL_NAME=gpt-4o-mini
# OPEN_AGENT_MAX_STEPS=10                    # max ReAct iterations per turn
# OPEN_AGENT_MAX_CONTEXT_TOKENS=8000         # max context window tokens per request
# OPEN_AGENT_REQUEST_TIMEOUT=60.0            # per-request timeout in seconds

# ---- Server settings ----
# OPEN_AGENT_SERVER_HOST=127.0.0.1           # bind host for the FastAPI server
# OPEN_AGENT_SERVER_PORT=8000                # bind port for the FastAPI server
# OPEN_AGENT_SHORT_TERM_MEMORY_SIZE=20       # recent messages kept in short-term memory
# OPEN_AGENT_SESSION_STORAGE_DIR=.open_agent_sessions  # directory for persisting sessions

# ---- Security settings ----
# OPEN_AGENT_API_AUTH_TOKEN=                 # API auth token; empty disables authentication
# OPEN_AGENT_CORS_ORIGINS=                   # comma-separated allowed CORS origins

# ---- RAG / embeddings ----
OPEN_AGENT_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
OPEN_AGENT_CHUNK_SIZE=500
OPEN_AGENT_CHUNK_OVERLAP=50
OPEN_AGENT_SPLIT_UNIT=char
OPEN_AGENT_RAG_TOP_K=5
OPEN_AGENT_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
OPEN_AGENT_RERANK_K=20

# ---- Tool settings ----
# OPEN_AGENT_MCP_SERVERS_FILE=mcp_servers.json  # path to MCP servers JSON config
# OPEN_AGENT_ENABLED_TOOLS=                  # comma-separated tool names; empty = all

# ---- Sandbox settings ----
# OPEN_AGENT_ENABLE_TOOL_SANDBOX=false       # enable filesystem sandbox for tools
# OPEN_AGENT_SANDBOX_ALLOWED_PATHS=          # comma-separated paths tools may access
# OPEN_AGENT_SANDBOX_BLOCKED_PATHS=          # comma-separated paths tools are denied

# ---- Long-term memory settings ----
# OPEN_AGENT_ENABLE_LONG_TERM_MEMORY=false   # enable vector-backed long-term memory
# OPEN_AGENT_LONG_TERM_MEMORY_DIR=.open_agent_long_term  # storage directory for long-term memory
# OPEN_AGENT_LONG_TERM_MEMORY_TOP_K=3        # number of long-term memories retrieved

# ---- Observability settings ----
OPEN_AGENT_ENABLE_OBSERVABILITY=true
OPEN_AGENT_OBSERVABILITY_PROVIDER=local
# OPEN_AGENT_OBSERVABILITY_OUTPUT_DIR=.open_agent_traces  # trace output directory
# LangSmith:
# OPEN_AGENT_OBSERVABILITY_PROVIDER=langsmith
# OPEN_AGENT_LANGSMITH_API_KEY=ls-...        # LangSmith personal API key
# OPEN_AGENT_LANGSMITH_API_URL=https://api.smith.langchain.com  # LangSmith API endpoint
# OPEN_AGENT_LANGSMITH_PROJECT=open-agent    # LangSmith project name
# Langfuse:
# OPEN_AGENT_OBSERVABILITY_PROVIDER=langfuse
# OPEN_AGENT_LANGFUSE_PUBLIC_KEY=            # Langfuse public key
# OPEN_AGENT_LANGFUSE_SECRET_KEY=            # Langfuse secret key
# OPEN_AGENT_LANGFUSE_HOST=https://cloud.langfuse.com  # Langfuse host URL
