# Copy this file to .env and fill in your values before running docker compose up.

# LLM provider configuration
OPEN_AGENT_MODEL_PROVIDER=openai
OPEN_AGENT_API_KEY=your-api-key-here
OPEN_AGENT_BASE_URL=https://api.openai.com/v1
OPEN_AGENT_MODEL_NAME=gpt-4o-mini

# RAG / embeddings
OPEN_AGENT_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
OPEN_AGENT_CHUNK_SIZE=500
OPEN_AGENT_CHUNK_OVERLAP=50
OPEN_AGENT_SPLIT_UNIT=char
OPEN_AGENT_RAG_TOP_K=5
OPEN_AGENT_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
OPEN_AGENT_RERANK_K=20

# Optional MCP servers configuration file (relative to project root)
# OPEN_AGENT_MCP_SERVERS_FILE=mcp_servers.json

# Observability (local tracing is enabled by default)
OPEN_AGENT_ENABLE_OBSERVABILITY=true
OPEN_AGENT_OBSERVABILITY_PROVIDER=local
# OPEN_AGENT_OBSERVABILITY_PROVIDER=langsmith
# OPEN_AGENT_LANGSMITH_API_KEY=ls-...
# OPEN_AGENT_LANGSMITH_PROJECT=open-agent
