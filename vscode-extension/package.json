{
  "name": "open-agent",
  "displayName": "Open Agent",
  "description": "Agentic RAG autonomous work assistant in VS Code",
  "version": "0.1.0",
  "publisher": "open-agent",
  "license": "MIT",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["AI", "Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        { "id": "open-agent", "title": "Open Agent", "icon": "media/icon.svg" }
      ]
    },
    "views": {
      "open-agent": [
        { "id": "openAgent.chat", "name": "Chat", "type": "webview" }
      ]
    },
    "commands": [
      {
        "command": "open-agent.sendPrompt",
        "title": "Open Agent: Send Prompt"
      },
      {
        "command": "open-agent.setApiUrl",
        "title": "Open Agent: Set API URL"
      },
      {
        "command": "open-agent.startBackend",
        "title": "Open Agent: Start Backend"
      },
      {
        "command": "open-agent.stopBackend",
        "title": "Open Agent: Stop Backend"
      },
      {
        "command": "open-agent.restartBackend",
        "title": "Open Agent: Restart Backend"
      }
    ],
    "configuration": {
      "title": "Open Agent",
      "properties": {
        "open-agent.apiUrl": {
          "type": "string",
          "default": "http://localhost:8000",
          "description": "URL of the Open Agent API server"
        },
        "open-agent.autoStartBackend": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the Open Agent Python backend when VS Code activates"
        },
        "open-agent.pythonExecutable": {
          "type": "string",
          "default": "python",
          "description": "Python executable used to start the backend"
        },
        "open-agent.backendCwd": {
          "type": "string",
          "default": "",
          "description": "Working directory for the backend process (defaults to the first workspace folder)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.12",
    "typescript": "^5.5.0"
  }
}
